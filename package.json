{
  "name": "git-top",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "next:dev": "next dev",
    "next:build": "next build",
    "next:start": "next start",
    "deploy": "wrangler deploy",
    "check": "tsc --noEmit",
    "seed:validate": "node scripts/validate-seed-repositories.mjs",
    "seed:coverage": "node scripts/seed-coverage.mjs",
    "seed:live-check": "node scripts/check-seed-live.mjs",
    "seed:candidates": "node scripts/find-seed-candidates.mjs",
    "knowledge:validate": "node --experimental-strip-types --import ./scripts/register-ts-loader.mjs scripts/validate-generated-knowledge.mjs",
    "db:validate": "node --experimental-strip-types --import ./scripts/register-ts-loader.mjs scripts/validate-db-mapping.mjs",
    "core:validate": "node --experimental-strip-types --import ./scripts/register-ts-loader.mjs scripts/validate-core-logic.mjs",
    "api:validate": "node --experimental-strip-types --import ./scripts/register-ts-loader.mjs scripts/validate-api-routes.mjs",
    "mcp:validate": "node --experimental-strip-types --import ./scripts/register-ts-loader.mjs scripts/validate-mcp-tools.mjs",
    "eval:quality": "node --experimental-strip-types --import ./scripts/register-ts-loader.mjs scripts/eval-quality.mjs",
    "eval:local": "node --experimental-strip-types --import ./scripts/register-ts-loader.mjs scripts/eval-local.mjs",
    "eval:ranking": "node --experimental-strip-types --import ./scripts/register-ts-loader.mjs scripts/eval-ranking-experiments.mjs",
    "quality:review": "node --experimental-strip-types --import ./scripts/register-ts-loader.mjs scripts/low-confidence-review.mjs",
    "db:seed-sql": "node --experimental-strip-types --import ./scripts/register-ts-loader.mjs scripts/generate-seed-sql.mjs",
    "db:integration": "node scripts/validate-local-d1-integration.mjs",
    "smoke:prod": "node scripts/smoke-prod.mjs",
    "sync:prod:catchup": "node scripts/sync-prod-catchup.mjs",
    "release:check": "node scripts/verify-public-v1.mjs",
    "validate": "pnpm seed:validate && pnpm seed:coverage && pnpm knowledge:validate && pnpm db:seed-sql && pnpm db:validate && pnpm core:validate && pnpm api:validate && pnpm mcp:validate && pnpm eval:quality && pnpm quality:review && pnpm check && pnpm next:build",
    "quality:check": "node scripts/check-quality.mjs",
    "db:prepare-local": "node scripts/prepare-local-d1.mjs",
    "db:execute": "pnpm db:prepare-local",
    "db:seed": "pnpm db:prepare-local && pnpm db:seed-sql && wrangler d1 execute git-top --local --file=./seed.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260612.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.8.3",
    "wrangler": "^4.20.5"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
